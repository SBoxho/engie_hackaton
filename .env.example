# Optional: only needed for the future ENTSO-E integration.
ENTSOE_API_TOKEN=

# Public endpoints can be overridden for testing or mirrors.
ODRE_BASE_URL=https://odre.opendatasoft.com/api/explore/v2.1
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
RTE_ECOWATT_API_URL=https://digital.iservices.rte-france.com/open_api/ecowatt/v5/signals
RTE_ECOWATT_API_TOKEN=

# Dashboard defaults
APP_MODE=demo
DEMO_ALLOW_EXTERNAL_API=0
ENERGY_PULSE_HISTORY_HOURS=72
ENERGY_PULSE_TIMEZONE=Europe/Paris
ENERGY_PULSE_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
ENERGY_PULSE_MAX_BODY_BYTES=65536
ENERGY_PULSE_HTTP_TIMEOUT_SECONDS=15
ENERGY_PULSE_HTTP_MAX_RETRIES=2
ENERGY_PULSE_HTTP_MIN_INTERVAL_SECONDS=0.25
ENERGY_PULSE_CIRCUIT_BREAKER_FAILURES=3
ENERGY_PULSE_CIRCUIT_BREAKER_RECOVERY_SECONDS=60
ENERGY_PULSE_DEMO_DATE_LABEL=fixed historical replay window from demo_data/manifest.json
